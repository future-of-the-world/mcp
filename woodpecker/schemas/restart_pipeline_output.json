{
  "type": "object",
  "properties": {
    "pipeline": {
      "type": "object",
      "description": "The newly-started pipeline, same shape as get_pipeline's output. workflows[] is included but will be empty until the new run begins.",
      "properties": {
        "number": { "type": "integer" },
        "event": { "type": "string" },
        "status": {
          "type": "string",
          "description": "pending once the new run is queued; success / failure once it completes."
        },
        "branch": { "type": "string" },
        "commit": { "type": "string" },
        "message": { "type": "string" },
        "author": { "type": "string" },
        "started": { "type": "integer" },
        "finished": { "type": "integer" },
        "duration": { "type": "integer" },
        "created": { "type": "integer" },
        "workflows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "state": { "type": "string" },
              "children": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer" },
                    "name": { "type": "string" },
                    "type": { "type": "string" },
                    "state": { "type": "string" },
                    "exit_code": { "type": "integer" },
                    "error": { "type": "string" }
                  },
                  "required": ["id", "name", "state"]
                }
              }
            },
            "required": ["id", "name", "state"]
          }
        }
      },
      "required": ["number", "status"]
    }
  },
  "required": ["pipeline"]
}
